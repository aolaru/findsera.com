---
interface Props {
  title: string;
  description: string;
  href?: string;
  linkLabel?: string;
}

const { title, description, href, linkLabel = "Explore all" } = Astro.props;
---

<div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
  <div class="max-w-2xl">
    <h2 class="font-serif text-3xl font-semibold tracking-tight text-ink-900">{title}</h2>
    <p class="mt-3 text-sm leading-7 text-ink-700">{description}</p>
  </div>

  {
    href && (
      <a
        href={href}
        class="inline-flex items-center gap-2 self-start rounded-full border border-black/10 bg-white px-4 py-2 text-sm font-semibold text-ink-900 shadow-sm hover:border-accent-500 hover:text-accent-600"
      >
        {linkLabel}
      </a>
    )
  }
</div>
