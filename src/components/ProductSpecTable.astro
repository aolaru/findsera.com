---
import { categoryLabels } from "../data/catalog";
import type { Product } from "../data/catalog";

interface Props {
  product: Product;
  useCase: string;
  secondaryUseCase: string;
  priceTier: string;
}

const { product, useCase, secondaryUseCase, priceTier } = Astro.props;

const rows = [
  ["Brand", product.brand],
  ["Category", categoryLabels[product.category]],
  ["Current catalog price", product.priceLabel],
  ["Price tier", priceTier],
  ["Primary use", useCase],
  ["Secondary use", secondaryUseCase],
  ["Retailer title", product.retailerTitle ?? product.title],
  ["Price checked", product.priceCheckedAt],
  ["Retailer path", product.affiliateMode === "exact" ? "Direct product listing" : "Amazon search results"],
  ["Tags", product.tags.join(", ")]
];
---

<article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Specs and buying details</p>
  <h2 class="mt-3 font-serif text-3xl font-semibold tracking-tight text-ink-900">
    Key details before you open Amazon
  </h2>
  <p class="mt-3 text-sm leading-7 text-ink-700">
    This table keeps the practical buying details visible in one place so the page is useful before you open a retailer listing.
  </p>
  <div class="mt-5 overflow-x-auto">
    <table class="min-w-full text-left text-sm text-ink-700">
      <tbody>
        {
          rows.map(([label, value]) => (
            <tr class="border-b border-black/6 last:border-b-0">
              <th class="w-48 py-3 pr-4 align-top text-xs font-semibold uppercase tracking-[0.16em] text-ink-700/70">
                {label}
              </th>
              <td class="py-3 text-ink-900">{value}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</article>
