---
import type { Cluster } from "../data/catalog";

interface Props {
  cluster: Cluster;
}

const { cluster } = Astro.props;
const guideGroupAnchors: Record<string, string> = {
  "budget-finds": "/guides/#budget",
  "coffee-gear": "/guides/#coffee",
  "home-office": "/guides/#desk-home-office",
  "precision-cooking": "/guides/#comparisons",
  "travel-tech": "/guides/#travel-tech"
};
const href = guideGroupAnchors[cluster.slug] ?? "/guides/";
---

<article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Guide collection</p>
  <h3 class="mt-3 font-serif text-2xl font-semibold tracking-tight text-ink-900">
    <a href={href} class="hover:text-accent-600">
      {cluster.title}
    </a>
  </h3>
  <p class="mt-4 text-sm leading-7 text-ink-700">{cluster.description}</p>
  <div class="mt-6 flex items-center justify-between gap-4 text-sm text-ink-700">
    <span>{cluster.roundupCount} guides</span>
    <a href={href} class="font-semibold text-ink-900 hover:text-accent-600">
      View guides
    </a>
  </div>
</article>
