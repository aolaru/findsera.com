---
interface Props {
  showTagline?: boolean;
  iconClass?: string;
  titleClass?: string;
  taglineClass?: string;
}

const {
  showTagline = false,
  iconClass = "h-11 w-11",
  titleClass = "font-serif text-xl font-semibold tracking-tight text-ink-900",
  taglineClass = "text-xs font-medium uppercase tracking-[0.2em] text-ink-700/80"
} = Astro.props;
---

<span class="inline-flex items-center gap-3">
  <svg
    viewBox="0 0 64 64"
    aria-hidden="true"
    class:list={[iconClass, "shrink-0 drop-shadow-[0_10px_24px_rgba(231,125,47,0.28)]"]}
  >
    <defs>
      <linearGradient id="findsera-mark-gradient" x1="10" x2="54" y1="8" y2="56" gradientUnits="userSpaceOnUse">
        <stop stop-color="#f4b15d"></stop>
        <stop offset="0.55" stop-color="#e97d2f"></stop>
        <stop offset="1" stop-color="#c95717"></stop>
      </linearGradient>
      <radialGradient id="findsera-mark-glow" cx="0" cy="0" r="1" gradientTransform="translate(22 18) rotate(51.4531) scale(30.7408 24.6771)" gradientUnits="userSpaceOnUse">
        <stop stop-color="#fff4db" stop-opacity="0.85"></stop>
        <stop offset="1" stop-color="#fff4db" stop-opacity="0"></stop>
      </radialGradient>
    </defs>
    <rect x="4" y="4" width="56" height="56" rx="18" fill="url(#findsera-mark-gradient)"></rect>
    <rect x="4" y="4" width="56" height="56" rx="18" fill="url(#findsera-mark-glow)"></rect>
    <path
      d="M22 17.5C22 16.67 22.67 16 23.5 16H44C44.83 16 45.5 16.67 45.5 17.5V20.5C45.5 21.33 44.83 22 44 22H29V29.5H40.5C41.33 29.5 42 30.17 42 31V34C42 34.83 41.33 35.5 40.5 35.5H29V46.5C29 47.33 28.33 48 27.5 48H23.5C22.67 48 22 47.33 22 46.5V17.5Z"
      fill="#fff9f1"
    ></path>
    <circle cx="46.5" cy="18.5" r="6.5" fill="#0f8b8d"></circle>
    <circle cx="46.5" cy="18.5" r="3" fill="#e9fffc"></circle>
  </svg>

  <span>
    <span class={titleClass}>Findsera</span>
    {
      showTagline && (
        <span class:list={[taglineClass, "block"]}>
          Curated product picks
        </span>
      )
    }
  </span>
</span>
