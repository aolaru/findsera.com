---
import BrandLogo from "./BrandLogo.astro";
import HeaderSearch from "./HeaderSearch.astro";
import { getSearchItems } from "../data/catalog";

const navItems = [
  { href: "/products", label: "Products" },
  { href: "/guides", label: "Guides" },
  { href: "/about", label: "About" },
  { href: "/search", label: "Search" }
];

const searchItems = getSearchItems();
---

<header class="sticky top-0 z-40 border-b border-black/5 bg-white/90 backdrop-blur">
  <div class="container-shell flex flex-col gap-4 py-4 lg:flex-row lg:items-center lg:justify-between">
    <div class="flex items-center justify-between gap-4">
      <a href="/" aria-label="Findsera home" class="inline-flex items-center">
        <BrandLogo showTagline={true} />
      </a>
      <nav class="flex items-center gap-4 text-sm font-semibold text-ink-700 lg:hidden" aria-label="Mobile navigation">
        <a href="/products" class="hover:text-accent-600">Products</a>
        <a href="/guides" class="hover:text-accent-600">Guides</a>
      </nav>
    </div>

    <div class="flex flex-col gap-4 lg:flex-row lg:items-center">
      <nav class="hidden items-center gap-6 text-sm font-semibold text-ink-700 lg:flex" aria-label="Main navigation">
        {navItems.map((item) => <a href={item.href} class="hover:text-accent-600">{item.label}</a>)}
      </nav>
      <HeaderSearch items={searchItems} />
    </div>
  </div>
</header>
