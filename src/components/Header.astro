---
import BrandLogo from "./BrandLogo.astro";
import HeaderSearch from "./HeaderSearch.astro";
import { getSearchItems } from "../data/catalog";

const navItems = [
  { href: "/", label: "Home" },
  { href: "/category/gadgets", label: "Gadgets" },
  { href: "/category/kitchen", label: "Kitchen" },
  { href: "/best-products-under-50", label: "Under $50" },
  { href: "/guides", label: "Guides" }
];

const currentPath = Astro.url.pathname;
const searchItems = getSearchItems();
---

<header class="sticky top-0 z-40 border-b border-black/5 bg-white/88 backdrop-blur-lg">
  <div class="container-shell flex flex-col gap-4 py-4 lg:flex-row lg:items-center lg:justify-between">
    <div class="flex items-center justify-between gap-6">
      <a href="/" class="inline-flex items-center gap-3 text-ink-900">
        <BrandLogo showTagline={true} iconClass="h-10 w-10" />
      </a>
    </div>

    <div class="flex flex-col gap-3 lg:flex-1 lg:flex-row lg:items-center lg:justify-end">
      <div class="w-full lg:max-w-md">
        <HeaderSearch items={searchItems} />
      </div>

      <nav aria-label="Primary" class="hidden items-center gap-2 md:flex">
        {
          navItems.map((item) => {
            const active = currentPath === item.href;

            return (
              <a
                href={item.href}
                class:list={[
                  "rounded-full px-4 py-2 text-sm font-semibold",
                  active
                    ? "bg-ink-900 text-white shadow-md"
                    : "text-ink-700 hover:bg-sand-100 hover:text-ink-900"
                ]}
              >
                {item.label}
              </a>
            );
          })
        }
      </nav>
    </div>
  </div>
</header>
