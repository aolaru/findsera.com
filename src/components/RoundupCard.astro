---
import type { Roundup } from "../data/catalog";

interface Props {
  roundup: Roundup;
}

const { roundup } = Astro.props;
---

<article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">{roundup.eyebrow}</p>
  <h3 class="mt-3 font-serif text-2xl font-semibold tracking-tight text-ink-900">
    <a href={`/${roundup.slug}`} class="hover:text-accent-600">
      {roundup.title}
    </a>
  </h3>
  <p class="mt-4 text-sm leading-7 text-ink-700">{roundup.description}</p>
  <div class="mt-6 flex items-center justify-between gap-4 text-sm text-ink-700">
    <span>{roundup.productCount} products</span>
    <a href={`/${roundup.slug}`} class="font-semibold text-ink-900 hover:text-accent-600">
      Read roundup
    </a>
  </div>
</article>
