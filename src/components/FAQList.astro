---
import type { RoundupFaq } from "../data/catalog";

interface Props {
  title?: string;
  items: RoundupFaq[];
}

const { title = "Frequently asked questions", items } = Astro.props;
---

<section class="rounded-[2rem] border border-black/6 bg-white p-6 shadow-card">
  <h2 class="font-serif text-3xl font-semibold tracking-tight text-ink-900">{title}</h2>
  <div class="mt-6 space-y-4">
    {
      items.map((item) => (
        <details class="rounded-[1.25rem] border border-black/8 bg-sand-50 px-5 py-4">
          <summary class="cursor-pointer list-none font-semibold text-ink-900">
            {item.question}
          </summary>
          <p class="mt-3 text-sm leading-7 text-ink-700">{item.answer}</p>
        </details>
      ))
    }
  </div>
</section>
