---
import { getProductFreshness } from "../data/catalog";
import type { Product } from "../data/catalog";

interface Props {
  product: Product;
}

const { product } = Astro.props;
const freshness = getProductFreshness(product);
---

<article class="group flex h-full flex-col overflow-hidden rounded-[1.75rem] border border-black/6 bg-white shadow-card">
  <div class="relative overflow-hidden border-b border-black/6 bg-[linear-gradient(180deg,#fff9ef,#fff)]">
    <a href={`/products/${product.slug}`} class="block">
      <img
        src={product.image}
        alt={product.title}
        loading="lazy"
        width="640"
        height="420"
        onerror="this.onerror=null;this.src='/images/product-placeholder.svg';"
        class="h-52 w-full object-contain p-5 duration-300 group-hover:scale-[1.03]"
      />
    </a>
    {
      product.isTrending && (
        <span class="absolute left-4 top-4 rounded-full bg-ink-900 px-3 py-1 text-xs font-bold uppercase tracking-[0.16em] text-white shadow-sm">
          Trending
        </span>
      )
    }
    {
      freshness && (
        <span
          title={freshness.description}
          class:list={[
            "absolute right-4 top-4 rounded-full px-3 py-1 text-xs font-bold uppercase tracking-[0.16em] shadow-sm",
            freshness.status === "new" ? "bg-accent-600 text-white" : "border border-black/8 bg-white text-ink-900"
          ]}
        >
          {freshness.label}
        </span>
      )
    }
  </div>

  <div class="flex flex-1 flex-col p-5">
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">
          {product.brand} · {product.category}
        </p>
        <h3 class="mt-2 font-serif text-2xl font-semibold tracking-tight text-ink-900">
          <a href={`/products/${product.slug}`} class="hover:text-accent-600">
            {product.title}
          </a>
        </h3>
      </div>
      <p class="rounded-full bg-sand-100 px-3 py-2 text-sm font-semibold text-ink-900">
        {product.priceLabel}
      </p>
    </div>

    <p class="mt-4 flex-1 text-sm leading-7 text-ink-700">{product.description}</p>

    <ul class="mt-4 space-y-2 text-sm text-ink-700">
      {product.highlights.slice(0, 2).map((item) => <li>- {item}</li>)}
    </ul>

    <div class="mt-4 flex flex-wrap items-center gap-2 text-xs font-medium uppercase tracking-[0.14em] text-ink-700/70">
      <span>Price checked {product.priceCheckedAt}</span>
      {freshness && <span class="text-accent-600">· {freshness.description}</span>}
    </div>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href={`/products/${product.slug}`}
        class="inline-flex items-center justify-center rounded-full border border-black/10 bg-white px-4 py-3 text-sm font-semibold text-ink-900 hover:border-accent-500 hover:text-accent-600"
      >
        View details
      </a>
      <a
        href={product.affiliateUrl}
        target="_blank"
        rel="noopener noreferrer sponsored"
        class="inline-flex items-center justify-center rounded-full bg-ink-900 px-4 py-3 text-sm font-semibold text-white hover:bg-accent-600"
      >
        View on Amazon
      </a>
    </div>
  </div>
</article>
