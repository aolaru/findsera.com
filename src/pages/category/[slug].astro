---
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import FAQList from "../../components/FAQList.astro";
import ProductCard from "../../components/ProductCard.astro";
import RoundupCard from "../../components/RoundupCard.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import TopicBadgeList from "../../components/TopicBadgeList.astro";
import {
  allTopics,
  categories,
  categoryDescriptions,
  categoryLabels,
  type ProductCategory,
  getProductsByCategory,
  getRoundupsByCategory
} from "../../data/catalog";
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
  return categories.map((category) => ({
    params: { slug: category.slug },
    props: {
      slug: category.slug,
      label: category.label,
      description: category.description,
      products: getProductsByCategory(category.slug),
      roundups: getRoundupsByCategory(category.slug),
      topics: allTopics
        .filter((topic) => Object.keys(topic.categoryCounts).includes(category.slug))
        .slice(0, 6)
    }
  }));
}

const { slug, label, description, products, roundups, topics } = Astro.props;
const title = `${label} Finds | Findsera`;
const metaDescription = `Browse ${label.toLowerCase()} picks on Findsera. ${description}`;

const categoryEditorial: Record<
  ProductCategory,
  {
    buyerNeed: string;
    selectionFocus: string;
    tradeoff: string;
    firstMove: string;
  }
> = {
  gadgets: {
    buyerNeed:
      "Gadget picks should help shoppers separate genuinely useful accessories from novelty tech. The strongest options support charging, travel, small-desk work, or everyday carry without demanding a complicated setup.",
    selectionFocus:
      "We look for products that solve repeat problems: a phone that runs low before the day ends, a laptop setup that needs a second screen, or a travel bag that needs lighter accessories.",
    tradeoff:
      "The common tradeoff is portability versus comfort or power. Smaller products are easier to carry, while larger chargers, monitors, and peripherals can make a temporary workspace feel more stable.",
    firstMove:
      "Start with the problem you notice most often: battery life, bag tracking, laptop ergonomics, or input control."
  },
  kitchen: {
    buyerNeed:
      "Kitchen picks focus on repeatable routines rather than one-off gadgets. The best products make coffee, cooking, measuring, or prep more consistent without adding too many steps.",
    selectionFocus:
      "We favor tools that improve the daily result: better pour control, easier milk texture, accurate measurements, reliable temperature checks, or more predictable batch cooking.",
    tradeoff:
      "The common tradeoff is counter space versus control. Premium tools can add precision, but compact products are often better for renters, beginners, and small kitchens.",
    firstMove:
      "Start with the routine you already repeat: morning coffee, weeknight cooking, meal prep, or better storage."
  },
  home: {
    buyerNeed:
      "Home picks cover comfort, organization, smart-home basics, and small-apartment upgrades. The goal is to highlight products that improve a room without turning it into a project.",
    selectionFocus:
      "We prioritize products with clear jobs: cleaner air near a desk, better lighting, easier storage, simple voice control, or small devices that make a room more convenient.",
    tradeoff:
      "The common tradeoff is simplicity versus ecosystem depth. A basic plug or lamp is easier to adopt, while connected devices can become more useful when they fit an existing smart-home setup.",
    firstMove:
      "Start with the room or routine that creates the most friction: bedroom comfort, desk focus, storage, cleaning, or simple automation."
  }
};

const editorial = categoryEditorial[slug];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: title,
  description: metaDescription,
  url: `https://findsera.com/category/${slug}/`,
  about: label,
  mainEntity: {
    "@type": "ItemList",
    itemListElement: products.map((product, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: product.affiliateUrl,
      name: product.title
    }))
  }
};
---

<Layout title={title} description={metaDescription} structuredData={structuredData}>
  <section class="section-spacing">
    <div class="container-shell">
      <Breadcrumbs items={[{ href: "/", label: "Home" }, { href: `/category/${slug}/`, label }]} />
      <span class="eyebrow">Category</span>
      <div class="mt-6 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div class="max-w-3xl">
          <h1 class="font-serif text-5xl font-semibold tracking-tight text-ink-900">{label}</h1>
          <p class="mt-4 text-lg leading-8 text-ink-700">{description}</p>
        </div>
        <a
          href="/"
          class="inline-flex items-center rounded-full border border-black/10 bg-white px-5 py-3 text-sm font-semibold text-ink-900 hover:border-accent-500 hover:text-accent-600"
        >
          Back to homepage
        </a>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="container-shell">
      <SectionHeader
        title={`Best ${categoryLabels[slug]} Products`}
        description={`${categoryDescriptions[slug]} Use the products below to compare practical fits before opening full product details or a buying roundup.`}
      />
      <div class="mb-8 grid gap-6 lg:grid-cols-3">
        <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">What belongs here</p>
          <p class="mt-4 text-sm leading-7 text-ink-700">{editorial.buyerNeed}</p>
        </article>
        <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">How to choose</p>
          <p class="mt-4 text-sm leading-7 text-ink-700">{editorial.selectionFocus}</p>
        </article>
        <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Main tradeoff</p>
          <p class="mt-4 text-sm leading-7 text-ink-700">{editorial.tradeoff}</p>
        </article>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
        {products.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>

  {
    roundups.length > 0 && (
      <section class="section-spacing">
        <div class="container-shell">
          <SectionHeader
            title={`Related ${label} Guides`}
            description={`Use these ${label.toLowerCase()} guides when you want a narrower product set built around a specific budget, room, routine, or comparison.`}
          />
          <div class="grid gap-6 lg:grid-cols-3">
            {roundups.map((roundup) => <RoundupCard roundup={roundup} />)}
          </div>
        </div>
      </section>
    )
  }

  {
    topics.length > 0 && (
      <section class="pb-16">
        <div class="container-shell">
          <SectionHeader
            title={`${label} Topics`}
            description="These topics narrow the category into more specific buying situations."
          />
          <TopicBadgeList topics={topics.map((topic) => ({ slug: topic.slug, title: topic.title }))} />
        </div>
      </section>
    )
  }

  <section class="section-spacing">
    <div class="container-shell">
      <FAQList
        title={`About ${label}`}
        items={[
          {
            question: `How should I start browsing ${label.toLowerCase()} products?`,
            answer: editorial.firstMove
          },
          {
            question: `Why are some ${label.toLowerCase()} products also in buying guides?`,
            answer:
              "Categories give the broad view, while guides narrow the decision around price, use case, room, or a direct product comparison."
          }
        ]}
      />
    </div>
  </section>
</Layout>
