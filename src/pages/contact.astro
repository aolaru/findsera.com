---
import Layout from "../layouts/Layout.astro";

const title = "Contact Findsera | Findsera";
const description =
  "Contact Findsera for editorial corrections, partnership questions, product-link issues, and general feedback about the site.";
---

<Layout title={title} description={description} canonicalPath="/contact">
  <section class="section-spacing">
    <div class="container-shell max-w-4xl">
      <span class="eyebrow">Contact</span>
      <h1 class="mt-6 font-serif text-5xl font-semibold tracking-tight text-ink-900 sm:text-6xl">
        Contact Findsera
      </h1>
      <p class="mt-5 text-lg leading-8 text-ink-700">
        For editorial corrections, broken affiliate links, partnership questions, or general feedback, use the current Findsera contact inbox below.
      </p>
    </div>
  </section>

  <section class="pb-20">
    <div class="container-shell grid gap-6 lg:grid-cols-[1fr,1fr]">
      <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
        <h2 class="font-serif text-3xl font-semibold tracking-tight text-ink-900">Email</h2>
        <p class="mt-4 text-sm leading-7 text-ink-700">
          <a href="mailto:hello@findsera.com" class="font-semibold text-accent-600 hover:text-accent-500">
            hello@findsera.com
          </a>
        </p>
        <p class="mt-3 text-sm leading-7 text-ink-700">
          Use this for product corrections, affiliate-link issues, editorial feedback, or brand outreach related to products that fit the site.
        </p>
      </article>

      <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
        <h2 class="font-serif text-3xl font-semibold tracking-tight text-ink-900">What to include</h2>
        <ul class="mt-4 space-y-3 text-sm leading-7 text-ink-700">
          <li>- The page URL if you are reporting a correction.</li>
          <li>- The product name if the issue is tied to a specific item.</li>
          <li>- A short description of the issue or request.</li>
        </ul>
      </article>
    </div>
  </section>
</Layout>
