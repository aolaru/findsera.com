---
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import FAQList from "../../components/FAQList.astro";
import ProductComparisonTable from "../../components/ProductComparisonTable.astro";
import ProductCard from "../../components/ProductCard.astro";
import RoundupCard from "../../components/RoundupCard.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { allRoundups, allTopics, categoryLabels, getProductsForTopic, getRoundupsForTopic } from "../../data/catalog";
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
  return allTopics.map((topic) => ({
    params: { slug: topic.slug },
    props: {
      topic,
      products: getProductsForTopic(topic),
      roundups: getRoundupsForTopic(topic)
    }
  }));
}

const { topic, products, roundups } = Astro.props;
const leadProduct = products[0];
const secondaryProduct = products[1];
const leadRoundup = roundups[0];
const topicName = topic.title.toLowerCase();
const dominantCategory = Object.entries(topic.categoryCounts).sort((a, b) => b[1] - a[1])[0]?.[0];
const dominantCategoryLabel = dominantCategory
  ? categoryLabels[dominantCategory as keyof typeof categoryLabels]
  : "Practical shopping";
const fallbackRoundups = dominantCategory
  ? allRoundups.filter((roundup) => roundup.category === dominantCategory).slice(0, 3)
  : [];
const displayRoundups = roundups.length > 0 ? roundups : fallbackRoundups;
const isThinTopic = topic.productCount < 2 && topic.roundupCount === 0;
const pageDescription =
  isThinTopic && leadProduct
    ? `${topic.title} product notes with nearby ${dominantCategoryLabel.toLowerCase()} guides for broader comparison.`
    : topic.productCount > 0
    ? `${topic.title} products and shopping guides for comparing practical picks by need, price, and everyday fit.`
    : `${topic.title} shopping guides organized around practical buying situations.`;
const comparisonProducts = products.slice(0, 5);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: topic.title,
  description: pageDescription,
  url: `https://findsera.com/topics/${topic.slug}/`,
  mainEntity: {
    "@type": "ItemList",
    itemListElement: [
      ...products.slice(0, 10).map((product, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: product.title,
        url: `https://findsera.com/products/${product.slug}/`
      })),
      ...roundups.slice(0, 10).map((roundup, index) => ({
        "@type": "ListItem",
        position: products.slice(0, 10).length + index + 1,
        name: roundup.title,
        url: `https://findsera.com/${roundup.slug}/`
      }))
    ]
  }
};
const faqItems = [
  {
    question: `What does the ${topic.title} topic cover?`,
    answer:
      topic.productCount > 0
        ? `It brings together ${topicName} products with similar buying jobs, so you can compare a smaller set before checking prices or variants.`
        : `It brings together ${topicName} shopping guides so you can start from a practical buying situation instead of a generic product grid.`
  },
  {
    question: `Where should I start with ${topic.title}?`,
    answer: leadProduct
      ? `Start with ${leadProduct.title}${secondaryProduct ? ` and compare it with ${secondaryProduct.title}` : ""}, then narrow by budget, room, routine, or tradeoff.`
      : "Start with the result that best matches your budget, room, routine, or comparison question."
  }
];
---

<Layout
  title={`${topic.title} | Findsera`}
  description={pageDescription}
  canonicalPath={`/topics/${topic.slug}/`}
  robots={isThinTopic ? "noindex, follow" : "index, follow"}
  image={leadProduct?.image ?? "/images/findsera-social-card.svg"}
  structuredData={structuredData}
>
  <section class="section-spacing">
    <div class="container-shell">
      <Breadcrumbs items={[{ href: "/", label: "Home" }, { href: `/topics/${topic.slug}/`, label: topic.title }]} />
      <span class="eyebrow">Topic tag</span>
      <h1 class="mt-6 font-serif text-5xl font-semibold tracking-tight text-ink-900">{topic.title}</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-ink-700">{pageDescription}</p>
      <div class="mt-8 grid gap-4 sm:grid-cols-3">
        <div class="rounded-[1.5rem] border border-black/6 bg-white p-5 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-accent-600">Products</p>
          <p class="mt-2 font-serif text-3xl font-semibold text-ink-900">{topic.productCount}</p>
        </div>
        {
          topic.roundupCount > 0 ? (
            <div class="rounded-[1.5rem] border border-black/6 bg-white p-5 shadow-card">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-accent-600">Guides</p>
              <p class="mt-2 font-serif text-3xl font-semibold text-ink-900">{topic.roundupCount}</p>
            </div>
          ) : (
            <div class="rounded-[1.5rem] border border-black/6 bg-white p-5 shadow-card">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-accent-600">Main category</p>
              <p class="mt-2 font-serif text-3xl font-semibold text-ink-900">{dominantCategoryLabel}</p>
            </div>
          )
        }
        <div class="rounded-[1.5rem] border border-black/6 bg-white p-5 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-accent-600">Best starting point</p>
          <p class="mt-2 text-sm font-semibold leading-6 text-ink-900">
            {leadProduct?.title ?? leadRoundup?.title ?? "Browse related guides"}
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-10">
    <div class="container-shell grid gap-6 lg:grid-cols-3">
      <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Start with {topic.title}</p>
        <p class="mt-4 text-sm leading-7 text-ink-700">
          {leadProduct
            ? `Start with ${leadProduct.title} if it matches the job you need solved, then compare price, setup effort, and the main tradeoff before opening a retailer listing.`
            : `Start with ${leadRoundup?.title ?? "the closest related guide"} when you need a narrower buying path for ${topicName}.`}
        </p>
      </article>
      <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Compare {topic.title}</p>
        <p class="mt-4 text-sm leading-7 text-ink-700">
          Compare the products by the job behind this topic, the price range you are willing to accept, and the setup
          friction you will notice after the first week.
        </p>
      </article>
      <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Use a guide when</p>
        <p class="mt-4 text-sm leading-7 text-ink-700">
          Use a related guide when the topic is still too broad, especially for budget limits, gift decisions,
          beginner setups, or direct comparisons between nearby products.
        </p>
      </article>
    </div>
  </section>

  <section class="pb-16">
    <div class="container-shell">
      <SectionHeader
        title={`${topic.title} Products`}
        description={
          isThinTopic
            ? `The current ${topicName} product match, with nearby guide paths below for broader comparison.`
            : `Products connected to ${topicName}, grouped for faster comparison.`
        }
      />
      {
        products.length > 0 ? (
          <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
            {products.map((product) => <ProductCard product={product} />)}
          </div>
        ) : (
          <div class="rounded-[1.75rem] border border-black/6 bg-white p-6 text-sm leading-7 text-ink-700 shadow-card">
            This topic is currently guide-led. Start with the related guides below for the strongest shopping paths.
          </div>
        )
      }
    </div>
  </section>

  {
    comparisonProducts.length > 1 && (
      <section class="pb-10">
        <div class="container-shell">
          <ProductComparisonTable
            products={comparisonProducts}
            title={`Compare ${topic.title} products`}
            description={`A compact comparison of the most relevant ${topicName} products, including price context, category fit, and current buying details.`}
          />
        </div>
      </section>
    )
  }

  {
    displayRoundups.length > 0 && (
      <section class="section-spacing">
        <div class="container-shell">
          <SectionHeader
            title={`${topic.title} Guide Paths`}
            description={
              roundups.length > 0
                ? `Related guides that make ${topicName} easier to compare by budget, use case, room, or product pair.`
                : `Nearby ${dominantCategoryLabel.toLowerCase()} guides to use when this topic has only one direct product match.`
            }
          />
          <div class="grid gap-6 lg:grid-cols-3">
            {displayRoundups.map((roundup) => <RoundupCard roundup={roundup} />)}
          </div>
        </div>
      </section>
    )
  }

  <section class="pb-20">
    <div class="container-shell">
      <FAQList title={`About ${topic.title}`} items={faqItems} />
    </div>
  </section>
</Layout>
