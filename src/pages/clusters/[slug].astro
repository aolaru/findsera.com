---
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ProductCard from "../../components/ProductCard.astro";
import RoundupCard from "../../components/RoundupCard.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import TopicBadgeList from "../../components/TopicBadgeList.astro";
import { allClusters, allTopics, getProductsForRoundup, getRoundupsForCluster } from "../../data/catalog";
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
  return allClusters.map((cluster) => {
    const roundups = getRoundupsForCluster(cluster);
    const products = [...new Map(roundups.flatMap((roundup) => getProductsForRoundup(roundup)).map((product) => [product.id, product])).values()];
    const relatedTopics = allTopics.filter((topic) => topic.slug === cluster.slug || topic.roundupSlugs.some((slug) => cluster.roundupSlugs.includes(slug)));

    return {
      params: { slug: cluster.slug },
      props: { cluster, roundups, products, relatedTopics }
    };
  });
}

const { cluster, roundups, products, relatedTopics } = Astro.props;
---

<Layout title={`${cluster.title} Cluster | Findsera`} description={cluster.description}>
  <section class="section-spacing">
    <div class="container-shell">
      <Breadcrumbs items={[{ href: "/", label: "Home" }, { href: `/clusters/${cluster.slug}`, label: cluster.title }]} />
      <span class="eyebrow">SEO cluster</span>
      <h1 class="mt-6 font-serif text-5xl font-semibold tracking-tight text-ink-900">{cluster.title}</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-ink-700">{cluster.description}</p>
    </div>
  </section>

  <section class="pb-16">
    <div class="container-shell">
      <SectionHeader
        title="Roundups in This Cluster"
        description="These pages target related search intent and are intended to support each other through internal linking."
      />
      <div class="grid gap-6 lg:grid-cols-3">
        {roundups.map((roundup) => <RoundupCard roundup={roundup} />)}
      </div>
    </div>
  </section>

  <section class="section-spacing">
    <div class="container-shell">
      <SectionHeader
        title="Core Products"
        description="Frequently recurring products inside this cluster, useful for broader landing pages and hub content."
      />
      <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
        {products.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>

  {
    relatedTopics.length > 0 && (
      <section class="section-spacing">
        <div class="container-shell">
          <SectionHeader
            title="Related Topic Tags"
            description="Topic tags add lighter-weight indexable pages around the same cluster."
          />
          <TopicBadgeList topics={relatedTopics.map((topic) => ({ slug: topic.slug, title: topic.title }))} />
        </div>
      </section>
    )
  }
</Layout>
