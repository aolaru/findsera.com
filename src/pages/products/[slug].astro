---
import AffiliateDisclosure from "../../components/AffiliateDisclosure.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import FAQList from "../../components/FAQList.astro";
import ProductComparisonTable from "../../components/ProductComparisonTable.astro";
import ProductCard from "../../components/ProductCard.astro";
import ProductSpecTable from "../../components/ProductSpecTable.astro";
import RoundupCard from "../../components/RoundupCard.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import TopicBadgeList from "../../components/TopicBadgeList.astro";
import {
  allProducts,
  categoryLabels,
  getProductFreshness,
  getProductPriceReview,
  getRelatedProducts,
  getRoundupsForProduct,
  getTopicsForProduct,
  type Product
} from "../../data/catalog";
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
  return allProducts.map((product) => {
    const relatedRoundups = getRoundupsForProduct(product).slice(0, 4);
    const relatedProducts = getRelatedProducts(product, 3);
    const relatedTopics = getTopicsForProduct(product).slice(0, 5);

    return {
      params: { slug: product.slug },
      props: {
        product,
        relatedRoundups,
        relatedProducts,
        relatedTopics
      }
    };
  });
}

const { product, relatedRoundups, relatedProducts, relatedTopics } = Astro.props as {
  product: Product;
  relatedRoundups: ReturnType<typeof getRoundupsForProduct>;
  relatedProducts: Product[];
  relatedTopics: { slug: string; title: string }[];
};

const categoryLabel = categoryLabels[product.category];
const priceReview = getProductPriceReview(product);
const formattedUpdatedAt = priceReview.checkedAtLabel;
const sourceIsAmazon = /^https?:\/\/(?:www\.)?amazon\./i.test(product.sourceUrl);
const sourceRel = sourceIsAmazon ? "noopener noreferrer nofollow" : "noopener noreferrer";
const sourceLabel = sourceIsAmazon ? "View source listing" : "View brand source";

const formatTag = (value: string) =>
  value
    .split("-")
    .map((chunk) => (chunk === "iphone" ? "iPhone" : chunk.charAt(0).toUpperCase() + chunk.slice(1)))
    .join(" ");

const useCase = product.tags[0] ? formatTag(product.tags[0].replace(/\s+/g, "-")) : categoryLabel;
const secondaryUseCase = product.tags[1] ? formatTag(product.tags[1].replace(/\s+/g, "-")) : "Everyday use";
const priceTier = product.price >= 120 ? "Upgrade" : product.price >= 70 ? "Mid-range" : "Accessible";
const freshness = getProductFreshness(product);
const editorial = product.editorial;
const editorialBestFor = editorial?.bestFor ?? useCase;
const pros = product.highlights.slice(0, 3);
const cons = [
  editorial?.skipIf ??
    (product.price >= 100
      ? `Costs more than most entry-level ${categoryLabel.toLowerCase()} alternatives.`
      : `Best when you want a clear ${useCase.toLowerCase()} fit, not the absolute cheapest option.`),
  product.tags.includes("travel")
    ? "Compact design can trade away some at-home-only comfort or capacity."
    : `Most useful for ${useCase.toLowerCase()} buyers rather than general-purpose shoppers.`
];
const trustReasons = [
  editorial?.verification ?? `${product.brand} product details and the current retailer path were checked for the buying notes on this page.`,
  `${product.title} is compared against ${relatedProducts.length} nearby alternative${relatedProducts.length === 1 ? "" : "s"} from the same category or use case.`,
  `The price reference was last checked on ${formattedUpdatedAt}. ${priceReview.description}`,
  product.affiliateMode === "exact"
    ? "The Amazon button opens a specific product listing."
    : "The Amazon button opens search results so you can verify seller, variant, and price."
].filter((item): item is string => Boolean(item));
const reviewScope =
  `${product.title} notes are based on product-page details, brand information where available, current retailer paths, price context, and comparisons with nearby alternatives. Hands-on testing or lab measurements are only used when they are explicitly stated.`;

const faqItems = [
  {
    question: `Who should buy the ${product.title}?`,
    answer:
      editorial?.buyIf ??
      `${product.title} makes the most sense for shoppers focused on ${useCase.toLowerCase()} and ${secondaryUseCase.toLowerCase()}, especially when they want a clearer fit than a generic bestseller list.`
  },
  {
    question: `What should I compare before buying ${product.title}?`,
    answer: `Compare the current price, seller, return window, variant, and whether the main tradeoff fits your routine: ${cons[0]}`
  },
  {
    question: `When was the ${product.title} price last checked?`,
    answer: `${product.title} was last checked on ${formattedUpdatedAt}. ${priceReview.description} Confirm the live total before buying because retailer prices and seller availability can move quickly.`
  }
];

const truncate = (value: string, maxLength = 155) =>
  value.length <= maxLength ? value : `${value.slice(0, maxLength - 1).replace(/\s+\S*$/, "")}.`;

const pageTitle = `${product.title} | Findsera`;
const pageDescription = truncate(product.description);

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: "https://findsera.com/" },
        {
          "@type": "ListItem",
          position: 2,
          name: categoryLabel,
          item: `https://findsera.com/category/${product.category}/`
        },
        {
          "@type": "ListItem",
          position: 3,
          name: product.title,
          item: `https://findsera.com/products/${product.slug}/`
        }
      ]
    },
    {
      "@type": "Product",
      name: product.title,
      brand: {
        "@type": "Brand",
        name: product.brand
      },
      description: product.description,
      category: categoryLabel,
      image: `https://findsera.com${product.image}`,
      sku: product.id,
      url: `https://findsera.com/products/${product.slug}/`,
      offers: {
        "@type": "Offer",
        priceCurrency: "USD",
        price: product.price,
        url: product.affiliateUrl,
        availability: "https://schema.org/InStock",
        itemCondition: "https://schema.org/NewCondition",
        priceValidUntil: priceReview.priceValidUntil
      }
    },
    {
      "@type": "FAQPage",
      mainEntity: faqItems.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer }
      }))
    }
  ]
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={`/products/${product.slug}/`}
  image={product.image}
  structuredData={structuredData}
>
  <section class="section-spacing">
    <div class="container-shell">
      <Breadcrumbs
        items={[
          { href: "/", label: "Home" },
          { href: `/category/${product.category}/`, label: categoryLabel },
          { href: `/products/${product.slug}/`, label: product.title }
        ]}
      />
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1.1fr),minmax(0,0.9fr)]">
        <div>
          <div class="mb-5 flex flex-wrap gap-3">
            <span class="rounded-full bg-sand-100 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-ink-900">
              {categoryLabel}
            </span>
            <span class="rounded-full border border-black/8 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-ink-700">
              Price reference {formattedUpdatedAt}
            </span>
            {
              priceReview.status !== "current" && (
                <span
                  title={priceReview.description}
                  class="rounded-full border border-black/8 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-accent-600"
                >
                  {priceReview.label}
                </span>
              )
            }
            {
              freshness && (
                <span
                  title={freshness.description}
                  class:list={[
                    "rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em]",
                    freshness.status === "new" ? "bg-accent-600 text-white" : "border border-black/8 bg-white text-ink-700"
                  ]}
                >
                  {freshness.label}
                </span>
              )
            }
            {
              product.isTrending && (
                <span class="rounded-full bg-ink-900 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-white">
                  Trending
                </span>
              )
            }
          </div>
          <span class="eyebrow">Product spotlight</span>
          <h1 class="mt-6 max-w-4xl font-serif text-5xl font-semibold tracking-tight text-ink-900 sm:text-6xl">
            {product.title}
          </h1>
          <p class="mt-5 max-w-3xl text-lg leading-8 text-ink-700">{product.description}</p>
          <div class="mt-8 flex flex-wrap gap-4">
            <p class="rounded-full bg-white px-5 py-3 text-base font-semibold text-ink-900 shadow-card">
              {product.priceLabel}
            </p>
            <p class="rounded-full border border-black/8 bg-white px-5 py-3 text-base font-semibold text-ink-700">
              {priceTier}
            </p>
            {
              freshness && (
                <p class="rounded-full border border-black/8 bg-white px-5 py-3 text-base font-semibold text-accent-600">
                  {freshness.description}
                </p>
              )
            }
          </div>
          <p class="mt-4 max-w-2xl rounded-[1.25rem] border border-black/6 bg-white px-4 py-3 text-sm leading-6 text-ink-700 shadow-sm">
            Findsera may earn a commission if you buy through qualifying links on this page. This does not change the
            price you pay.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href={product.affiliateUrl}
              target="_blank"
              rel="noopener noreferrer sponsored"
              class="inline-flex items-center rounded-full bg-ink-900 px-5 py-3 text-sm font-semibold text-white hover:bg-accent-600"
            >
              View on Amazon
            </a>
            <a
              href={product.sourceUrl}
              target="_blank"
              rel={sourceRel}
              class="inline-flex items-center rounded-full border border-black/10 bg-white px-5 py-3 text-sm font-semibold text-ink-900 hover:border-accent-500 hover:text-accent-600"
            >
              {sourceLabel}
            </a>
          </div>
          <div class="mt-8 rounded-[1.5rem] border border-black/6 bg-sand-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Quick verdict</p>
            <p class="mt-3 text-sm leading-7 text-ink-700">
              {
                editorial?.buyIf ??
                  `${product.title} is strongest when ${useCase.toLowerCase()} matters more than chasing a random bestseller.`
              }
            </p>
          </div>
        </div>

        <aside class="rounded-[2rem] border border-black/6 bg-white p-6 shadow-card">
          <div class="overflow-hidden rounded-[1.5rem] border border-black/6 bg-[linear-gradient(180deg,#fff9ef,#fff)] p-6">
            <img
              src={product.image}
              alt={product.title}
              width="640"
              height="420"
              onerror="this.onerror=null;this.src='/images/product-placeholder.svg';"
              class="h-72 w-full object-contain"
            />
          </div>
          <div class="mt-6 rounded-[1.5rem] bg-sand-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Best for</p>
            <p class="mt-3 text-lg font-semibold text-ink-900">{editorialBestFor}</p>
            <p class="mt-2 text-sm leading-7 text-ink-700">
              {
                editorial?.whyIncluded ??
                  `This pick is strongest when the buyer cares most about ${useCase.toLowerCase()} rather than just finding the cheapest option.`
              }
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="pb-10">
    <div class="container-shell space-y-8">
      <AffiliateDisclosure />
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr),minmax(0,1fr)]">
        <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Editorial decision notes</p>
          <h2 class="mt-3 font-serif text-3xl font-semibold tracking-tight text-ink-900">
            A clearer fit for {editorialBestFor.toLowerCase()}
          </h2>
          <p class="mt-4 text-sm leading-7 text-ink-700">
            {
              editorial?.whyIncluded ??
                `${product.title} is most useful when the job is clear and the tradeoff is acceptable. It should solve a real routine, not just add another spec to compare.`
            }
          </p>
          {
            editorial && (
              <div class="mt-5 grid gap-4 sm:grid-cols-2">
                <div class="rounded-[1.5rem] bg-sand-50 p-4">
                  <p class="text-xs font-semibold uppercase tracking-[0.16em] text-accent-600">Buy if</p>
                  <p class="mt-2 text-sm leading-7 text-ink-700">{editorial.buyIf}</p>
                </div>
                <div class="rounded-[1.5rem] bg-sand-50 p-4">
                  <p class="text-xs font-semibold uppercase tracking-[0.16em] text-accent-600">Skip if</p>
                  <p class="mt-2 text-sm leading-7 text-ink-700">{editorial.skipIf}</p>
                </div>
              </div>
            )
          }
        </article>

        <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Shopping snapshot</p>
          <dl class="mt-4 space-y-4 text-sm text-ink-700">
            <div>
              <dt class="font-semibold text-ink-900">Brand</dt>
              <dd>{product.brand}</dd>
            </div>
            <div>
              <dt class="font-semibold text-ink-900">Category</dt>
              <dd>{categoryLabel}</dd>
            </div>
            <div>
              <dt class="font-semibold text-ink-900">Primary use case</dt>
              <dd>{useCase}</dd>
            </div>
            <div>
              <dt class="font-semibold text-ink-900">Secondary use case</dt>
              <dd>{secondaryUseCase}</dd>
            </div>
          </dl>
          {relatedTopics.length > 0 && (
            <div class="mt-6">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Related topics</p>
              <div class="mt-4">
                <TopicBadgeList topics={relatedTopics} />
              </div>
            </div>
          )}
        </article>
      </div>
      <ProductSpecTable
        product={product}
        useCase={useCase}
        secondaryUseCase={secondaryUseCase}
        priceTier={priceTier}
        title={`Buying details for ${product.title}`}
      />
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr),minmax(0,1fr)]">
        <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Pros and cons</p>
          <div class="mt-5 grid gap-5 sm:grid-cols-2">
            <div>
              <p class="text-sm font-semibold text-ink-900">Pros</p>
              <ul class="mt-3 space-y-2 text-sm leading-7 text-ink-700">
                {pros.map((item) => <li>+ {item}</li>)}
              </ul>
            </div>
            <div>
              <p class="text-sm font-semibold text-ink-900">Consider before buying</p>
              <ul class="mt-3 space-y-2 text-sm leading-7 text-ink-700">
                {cons.map((item) => <li>- {item}</li>)}
              </ul>
            </div>
          </div>
        </article>

        <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Why trust this pick</p>
          <h2 class="mt-3 font-serif text-3xl font-semibold tracking-tight text-ink-900">
            What was checked for {product.title}
          </h2>
          <p class="mt-4 text-sm leading-7 text-ink-700">{reviewScope}</p>
          <ul class="mt-5 space-y-3 text-sm leading-7 text-ink-700">
            {trustReasons.map((item) => <li>- {item}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>

  {relatedRoundups.length > 0 && (
    <section class="pb-10">
      <div class="container-shell">
        <SectionHeader
          title={`Guides featuring ${product.title}`}
          description={`Compare ${product.title} with nearby picks when budget, room, routine, or gift fit matters.`}
        />
        <div class="grid gap-6 md:grid-cols-2">
          {relatedRoundups.map((roundup) => <RoundupCard roundup={roundup} />)}
        </div>
      </div>
    </section>
  )}

  {relatedProducts.length > 0 && (
    <section class="pb-10">
      <div class="container-shell">
        <SectionHeader
          title={`Similar ${categoryLabel.toLowerCase()} picks`}
          description={`Nearby alternatives to ${product.title} from the same category or shopping need.`}
        />
        <div class="mb-6 grid gap-4 lg:grid-cols-3">
          {relatedProducts.map((entry) => (
            <article class="rounded-[1.5rem] border border-black/6 bg-white p-5 shadow-card">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-accent-600">
                Better if you need {entry.tags[0] ? formatTag(entry.tags[0].replace(/\s+/g, "-")) : categoryLabel}
              </p>
              <h3 class="mt-3 font-serif text-2xl font-semibold tracking-tight text-ink-900">
                <a href={`/products/${entry.slug}/`} class="hover:text-accent-600">{entry.title}</a>
              </h3>
              <p class="mt-3 text-sm leading-7 text-ink-700">{entry.highlights[0]}</p>
            </article>
          ))}
        </div>
        <div class="mb-6">
          <ProductComparisonTable
            products={[product, ...relatedProducts]}
            title={`Compare ${product.title} alternatives`}
            description={`A spec-style view of ${product.title} against similar products from the same category or shopping need.`}
          />
        </div>
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {relatedProducts.map((entry) => <ProductCard product={entry} />)}
        </div>
      </div>
    </section>
  )}

  <section class="pb-20">
    <div class="container-shell space-y-6">
      <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Current listing check</p>
            <h2 class="mt-3 font-serif text-3xl font-semibold tracking-tight text-ink-900">
              Check current listing for {product.title}
            </h2>
            <p class="mt-3 text-sm leading-7 text-ink-700">
              If the product still matches what you need, use the Amazon link below to check the current price, variants, and availability.
            </p>
          </div>
          <a
            href={product.affiliateUrl}
            target="_blank"
            rel="noopener noreferrer sponsored"
            class="inline-flex items-center rounded-full bg-ink-900 px-5 py-3 text-sm font-semibold text-white hover:bg-accent-600"
          >
            View on Amazon
          </a>
        </div>
      </article>
      <FAQList title={`Questions about ${product.title}`} items={faqItems} />
    </div>
  </section>
</Layout>
