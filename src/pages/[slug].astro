---
import AffiliateDisclosure from "../components/AffiliateDisclosure.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import FAQList from "../components/FAQList.astro";
import ProductComparisonTable from "../components/ProductComparisonTable.astro";
import ProductCard from "../components/ProductCard.astro";
import RoundupCard from "../components/RoundupCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import TopicBadgeList from "../components/TopicBadgeList.astro";
import { allRoundups, allTopics, categoryLabels, getProductsForRoundup } from "../data/catalog";
import Layout from "../layouts/Layout.astro";

export function getStaticPaths() {
  return allRoundups.map((roundup) => ({
    params: { slug: roundup.slug },
    props: {
      roundup,
      products: getProductsForRoundup(roundup),
      relatedRoundups: allRoundups
        .filter((entry) => entry.slug !== roundup.slug && entry.category === roundup.category)
        .slice(0, 3),
      relatedTopics: allTopics.filter((topic) => topic.roundupSlugs.includes(roundup.slug)).slice(0, 5)
    }
  }));
}

const { roundup, products, relatedRoundups, relatedTopics } = Astro.props;
const formattedUpdatedAt = new Date(`${roundup.updatedAt}T00:00:00Z`).toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
  timeZone: "UTC"
});

const formatTag = (value: string) =>
  value
    .split("-")
    .map((chunk) => chunk.charAt(0).toUpperCase() + chunk.slice(1))
    .join(" ");

const getBestForLabel = (product: (typeof products)[number]) => {
  const priorityTags = ["travel", "office", "desk setup", "coffee", "brewing", "under-50", "gift"];
  const matchingTag = priorityTags.find((tag) => product.tags.includes(tag)) ?? product.tags[0];
  return matchingTag ? `Best for ${formatTag(matchingTag.replace(/\s+/g, "-"))}` : "Best overall pick";
};

const getTradeoff = (product: (typeof products)[number]) => {
  if (product.affiliateMode === "search") {
    return "Amazon availability can change, so compare the listing details before buying.";
  }

  if (product.price >= 120) {
    return "Higher price point than entry-level alternatives.";
  }

  if (product.price >= 80) {
    return "Better as an upgrade buy than a low-cost first purchase.";
  }

  return "Best when the buyer wants a specific use-case fit, not the cheapest option.";
};

const topPick = products[0];
const budgetPick = [...products].sort((a, b) => a.price - b.price)[0];
const upgradePick = [...products].sort((a, b) => b.price - a.price)[0];
const exactLinkCount = products.filter((product) => product.affiliateMode === "exact").length;
const isComparisonGuide = roundup.slug.includes("-vs-") && products.length >= 2;
const comparisonProducts = products.slice(0, 2);
const editorial = roundup.editorial;
const decisionSummary = editorial?.decisionSummary;
const categoryLabel = roundup.category ? categoryLabels[roundup.category] : "All categories";
const guideTitle = `${roundup.title} | Findsera`;
const quickDecisionCards = [
  {
    label: "Best overall",
    title: decisionSummary?.bestOverall ?? topPick.title,
    note: topPick.editorial?.bestFor ?? getBestForLabel(topPick)
  },
  {
    label: "Best value",
    title: decisionSummary?.bestBudget ?? budgetPick.title,
    note: decisionSummary ? "Lowest-friction value path" : budgetPick.priceLabel
  },
  {
    label: "Upgrade pick",
    title: decisionSummary?.bestUpgrade ?? upgradePick.title,
    note: decisionSummary ? "Worth it when the routine needs more control" : upgradePick.priceLabel
  }
];

const boundaryDecisionCards = decisionSummary
  ? [
      {
        label: "Skip these picks if",
        title: decisionSummary.skipIf,
        note: "A narrower product set will be more useful."
      },
      {
        label: "Read instead if",
        title: decisionSummary.readInstead.label,
        href: decisionSummary.readInstead.href,
        note: decisionSummary.readInstead.reason
      }
    ]
  : [];

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: "https://findsera.com/" },
        {
          "@type": "ListItem",
          position: 2,
          name: roundup.title,
          item: `https://findsera.com/${roundup.slug}/`
        }
      ]
    },
    {
      "@type": "CollectionPage",
      name: roundup.seoTitle,
      description: roundup.description,
      url: `https://findsera.com/${roundup.slug}/`,
      dateModified: roundup.updatedAt,
      mainEntity: {
        "@type": "ItemList",
        itemListElement: products.map((product, index) => ({
          "@type": "ListItem",
          position: index + 1,
          item: {
            "@type": "Product",
            name: product.title,
            brand: {
              "@type": "Brand",
              name: product.brand
            },
            description: product.description,
            image: `https://findsera.com${product.image}`,
            url: `https://findsera.com/products/${product.slug}/`,
            offers: {
              "@type": "Offer",
              priceCurrency: "USD",
              price: product.price,
              url: product.affiliateUrl,
              availability: "https://schema.org/InStock"
            }
          }
        }))
      }
    },
    {
      "@type": "FAQPage",
      mainEntity: roundup.faqs.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer }
      }))
    }
  ]
};
---

<Layout
  title={guideTitle}
  description={roundup.description}
  canonicalPath={`/${roundup.slug}/`}
  image={topPick.image}
  structuredData={structuredData}
>
  <section class="section-spacing">
    <div class="container-shell">
      <Breadcrumbs items={[{ href: "/", label: "Home" }, { href: `/${roundup.slug}/`, label: roundup.title }]} />
      <span class="eyebrow">{roundup.eyebrow}</span>
      <div class="mt-6 grid gap-8 lg:grid-cols-[minmax(0,1fr),20rem]">
        <div>
          <div class="mb-5 flex flex-wrap gap-3">
            <span class="rounded-full bg-sand-100 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-ink-900">
              Last updated {formattedUpdatedAt}
            </span>
            <span class="rounded-full border border-black/8 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-ink-700">
              Shortlist reviewed
            </span>
            {
              editorial && (
                <span class="rounded-full border border-black/8 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-ink-700">
                  Decision notes
                </span>
              )
            }
          </div>
          <h1 class="max-w-4xl font-serif text-5xl font-semibold tracking-tight text-ink-900 sm:text-6xl">
            {roundup.title}
          </h1>
          <p class="mt-5 max-w-3xl text-lg leading-8 text-ink-700">{roundup.intro}</p>
          <div class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-5">
            {[...quickDecisionCards, ...boundaryDecisionCards].map((item) => (
              <article class="rounded-[1.5rem] border border-black/6 bg-white p-4 shadow-card">
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-accent-600">{item.label}</p>
                {
                  item.href ? (
                    <a href={item.href} class="mt-3 block font-semibold text-ink-900 hover:text-accent-600">
                      {item.title}
                    </a>
                  ) : (
                    <p class="mt-3 font-semibold text-ink-900">{item.title}</p>
                  )
                }
                <p class="mt-2 text-sm text-ink-700">{item.note}</p>
              </article>
            ))}
          </div>
          <p class="mt-5 max-w-2xl rounded-[1.25rem] border border-black/6 bg-white px-4 py-3 text-sm leading-6 text-ink-700 shadow-sm">
            Findsera may earn a commission if you buy through qualifying links on this guide. Prices and availability
            can change after the listed check date.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href={topPick.affiliateUrl}
              target="_blank"
              rel="noopener noreferrer sponsored"
              class="inline-flex items-center rounded-full bg-ink-900 px-5 py-3 text-sm font-semibold text-white hover:bg-accent-600"
            >
              Shop best overall
            </a>
            <a
              href="#comparison"
              class="inline-flex items-center rounded-full border border-black/10 bg-white px-5 py-3 text-sm font-semibold text-ink-900 hover:border-accent-500 hover:text-accent-600"
            >
              Compare picks
            </a>
          </div>
        </div>

        <aside class="rounded-[2rem] border border-black/6 bg-white p-6 shadow-card">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent-600">Guide snapshot</p>
          <dl class="mt-5 space-y-4 text-sm text-ink-700">
            <div>
              <dt class="font-semibold text-ink-900">Updated</dt>
              <dd>{formattedUpdatedAt}</dd>
            </div>
            <div>
              <dt class="font-semibold text-ink-900">Products</dt>
              <dd>{products.length}</dd>
            </div>
            <div>
              <dt class="font-semibold text-ink-900">Purpose</dt>
              <dd>{editorial?.audience ?? "A short buying guide for comparing practical picks quickly."}</dd>
            </div>
          </dl>
          <div class="mt-6 rounded-[1.5rem] bg-sand-50 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Quick picks</p>
            <p class="mt-3 text-sm font-semibold text-ink-900">Best overall: {topPick.title}</p>
            <p class="mt-1 text-sm text-ink-700">Budget angle: {budgetPick.title}</p>
          </div>
          <a
            href="#top-picks"
            class="mt-6 inline-flex w-full items-center justify-center rounded-full bg-ink-900 px-4 py-3 text-sm font-semibold text-white hover:bg-accent-600"
          >
            Jump to top picks
          </a>
        </aside>
      </div>
    </div>
  </section>

  <section class="pb-10" id="top-picks">
    <div class="container-shell space-y-8">
      <AffiliateDisclosure />
      <div class="grid gap-6 lg:grid-cols-3">
        <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Review status</p>
          <h2 class="mt-3 font-serif text-2xl font-semibold tracking-tight text-ink-900">
            {categoryLabel} shortlist reviewed
          </h2>
          <p class="mt-4 text-sm leading-7 text-ink-700">
            Last reviewed on {formattedUpdatedAt}. This set includes {products.length}
            products, with {exactLinkCount} direct retailer product links where available.{" "}
            {editorial?.reviewNote}
          </p>
        </article>
        <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">How to choose</p>
          <h2 class="mt-3 font-serif text-2xl font-semibold tracking-tight text-ink-900">
            Choose by the job this purchase needs to handle
          </h2>
          <p class="mt-4 text-sm leading-7 text-ink-700">
            {
              topPick.editorial?.buyIf ??
                `Pick ${topPick.title} when you want the broadest fit, ${budgetPick.title} when price matters most, and ${upgradePick.title} when the upgrade is worth the extra spend.`
            }
          </p>
        </article>
        <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">More ways to compare</p>
          <h2 class="mt-3 font-serif text-2xl font-semibold tracking-tight text-ink-900">
            What narrows this guide
          </h2>
          <p class="mt-4 text-sm leading-7 text-ink-700">
            {editorial?.audience ?? "Compare the same products by budget, gift fit, setup effort, or the daily routine they are meant to improve."}
          </p>
        </article>
      </div>
      <SectionHeader
        title={`${roundup.eyebrow} shortlist`}
        description={`A focused set of ${products.length} picks for ${roundup.eyebrow.toLowerCase()}.`}
      />
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1.25fr),minmax(0,0.75fr)]">
        <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Why we picked these</p>
          <h2 class="mt-3 font-serif text-3xl font-semibold tracking-tight text-ink-900">
            Why these {products.length} products made the list
          </h2>
          <p class="mt-4 text-sm leading-7 text-ink-700">
            {
              editorial?.reviewNote ??
                "These picks favor products with clear jobs and visible differences, so each option covers a distinct buyer scenario."
            }
          </p>
          <ul class="mt-5 space-y-3 text-sm text-ink-700">
            {
              (editorial?.selectionCriteria ?? [
                "Everyday-use framing instead of generic feature dumping",
                "A useful spread across budget, upgrade, and specific use cases",
                "Preference for direct product links when available"
              ]).map((criterion) => <li>- {criterion}</li>)
            }
          </ul>
        </article>

        <ProductComparisonTable
          products={products}
          title="Compare price, fit, and tradeoffs"
          description="A quick spec-style view of the products below, including strongest use case, main reason to buy, current listed price, and last price-check date."
        />
      </div>
      {
        isComparisonGuide && (
          <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Buying verdict</p>
            <h2 class="mt-3 font-serif text-3xl font-semibold tracking-tight text-ink-900">
              Which one should you buy?
            </h2>
            <p class="mt-4 text-sm leading-7 text-ink-700">
              Choose {comparisonProducts[0].title} if the first job described below matches your routine. Choose{" "}
              {comparisonProducts[1].title} if the second job is the more common problem. The better pick is the one
              that removes the most frequent friction, not the one with the longest feature list.
            </p>
            <div class="mt-6 grid gap-4 md:grid-cols-2">
              {comparisonProducts.map((product, index) => (
                <div class="rounded-[1.5rem] bg-sand-50 p-5">
                  <p class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-700/70">
                    Buy {product.title} if
                  </p>
                  <h3 class="mt-3 text-lg font-semibold text-ink-900">
                    {roundup.sections[index]?.title ?? `${product.title} better fits your routine`}
                  </h3>
                  <p class="mt-3 text-sm leading-7 text-ink-700">
                    {roundup.sections[index]?.body ?? product.description}
                  </p>
                  <a
                    href={product.affiliateUrl}
                    target="_blank"
                    rel="noopener noreferrer sponsored"
                    class="mt-5 inline-flex items-center rounded-full bg-ink-900 px-4 py-3 text-sm font-semibold text-white hover:bg-accent-600"
                  >
                    View {product.title}
                  </a>
                </div>
              ))}
            </div>
          </article>
        )
      }
      <div class="grid gap-6 lg:grid-cols-[minmax(0,0.85fr),minmax(0,1.15fr)]">
        <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Who these picks fit</p>
          <h2 class="mt-3 font-serif text-3xl font-semibold tracking-tight text-ink-900">
            Best fit for this guide
          </h2>
          <p class="mt-4 text-sm leading-7 text-ink-700">
            {
              editorial?.audience ??
                "Best for shoppers who already know the use case and want a confident set of options, not an endless grid of barely differentiated products."
            }
          </p>
        </article>

        <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">What we checked</p>
          <h2 class="mt-3 font-serif text-3xl font-semibold tracking-tight text-ink-900">
            Checks used for {roundup.eyebrow.toLowerCase()}
          </h2>
          <ul class="mt-5 space-y-3 text-sm leading-7 text-ink-700">
            {
              (editorial?.whatChecked ?? editorial?.selectionCriteria ?? [
                "Products are chosen for a clear use case, not to inflate the list length.",
                "Preference goes to products that are easy to compare and act on.",
                "The product set stays tight so differences are easier to understand."
              ]).map((criterion) => <li>- {criterion}</li>)
            }
          </ul>
        </article>
      </div>

      <div class="grid gap-6 lg:grid-cols-[minmax(0,1.1fr),minmax(0,0.9fr)]">
        <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Trust signals</p>
          <div class="mt-4 grid gap-4 sm:grid-cols-3">
            <div class="rounded-[1.5rem] bg-sand-50 p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-700/70">Updated</p>
              <p class="mt-2 text-sm font-semibold text-ink-900">{formattedUpdatedAt}</p>
            </div>
            <div class="rounded-[1.5rem] bg-sand-50 p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-700/70">Affiliate links</p>
              <p class="mt-2 text-sm font-semibold text-ink-900">
                {exactLinkCount} direct product link{exactLinkCount === 1 ? "" : "s"}
              </p>
            </div>
            <div class="rounded-[1.5rem] bg-sand-50 p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-700/70">Picks</p>
              <p class="mt-2 text-sm font-semibold text-ink-900">{products.length} tightly matched picks</p>
            </div>
          </div>
        </article>
        <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Ready to shop</p>
          <h2 class="mt-3 font-serif text-3xl font-semibold tracking-tight text-ink-900">
            Start with the closest match
          </h2>
          <p class="mt-4 text-sm leading-7 text-ink-700">
            Start with {topPick.title} if the main need matches your routine. Use {budgetPick.title} when budget is
            tighter, and compare {upgradePick.title} when the extra spend solves a specific limitation.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href={topPick.affiliateUrl}
              target="_blank"
              rel="noopener noreferrer sponsored"
              class="inline-flex items-center rounded-full bg-ink-900 px-5 py-3 text-sm font-semibold text-white hover:bg-accent-600"
            >
              View {topPick.title}
            </a>
            <a
              href={budgetPick.affiliateUrl}
              target="_blank"
              rel="noopener noreferrer sponsored"
              class="inline-flex items-center rounded-full border border-black/10 bg-white px-5 py-3 text-sm font-semibold text-ink-900 hover:border-accent-500 hover:text-accent-600"
            >
              See value pick
            </a>
          </div>
        </article>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
        {
          products.map((product) => (
            <div class="space-y-4">
              <div class="rounded-[1.5rem] border border-black/6 bg-white p-5 shadow-card">
                <div class="flex items-center justify-between gap-4">
                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">
                    {getBestForLabel(product)}
                  </p>
                  <p class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-700/70">
                    {product.affiliateMode === "exact" ? "Direct product link" : "Amazon search link"}
                  </p>
                </div>
                <h3 class="mt-3 font-serif text-2xl font-semibold tracking-tight text-ink-900">
                  Why {product.title} stands out
                </h3>
                <p class="mt-3 text-sm leading-7 text-ink-700">
                  {product.editorial?.whyIncluded ?? product.description}
                </p>
                <div class="mt-5 grid gap-4 sm:grid-cols-2">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-700/70">Buy if</p>
                    <p class="mt-2 text-sm leading-7 text-ink-700">
                      {product.editorial?.buyIf ?? product.highlights[0]}
                    </p>
                  </div>
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-700/70">
                      Consider before buying
                    </p>
                    <p class="mt-2 text-sm leading-7 text-ink-700">
                      {product.editorial?.skipIf ?? getTradeoff(product)}
                    </p>
                  </div>
                </div>
              </div>
              <ProductCard product={product} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {
    relatedTopics.length > 0 && (
      <section class="pb-10">
        <div class="container-shell">
          <SectionHeader
            title="Related Topics"
            description="Use these tags to keep browsing products and guides around the same theme."
          />
          <TopicBadgeList topics={relatedTopics.map((topic) => ({ slug: topic.slug, title: topic.title }))} />
        </div>
      </section>
    )
  }

  <section class="section-spacing">
    <div class="container-shell grid gap-6 xl:grid-cols-2">
      {
        roundup.sections.map((section) => (
          <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
            <h2 class="font-serif text-3xl font-semibold tracking-tight text-ink-900">{section.title}</h2>
            <p class="mt-4 text-sm leading-7 text-ink-700">{section.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section-spacing">
    <div class="container-shell">
      <FAQList items={roundup.faqs} />
    </div>
  </section>

  {
    relatedRoundups.length > 0 && (
      <section class="section-spacing">
        <div class="container-shell">
          <SectionHeader
            title="Related Guides"
            description="More buying guides that may help narrow the choice."
          />
          <div class="grid gap-6 lg:grid-cols-3">
            {relatedRoundups.map((entry) => <RoundupCard roundup={entry} />)}
          </div>
        </div>
      </section>
    )
  }
</Layout>
