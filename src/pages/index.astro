---
import HeaderSearch from "../components/HeaderSearch.astro";
import RoundupCard from "../components/RoundupCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { allProducts, allRoundups, getSearchItems } from "../data/catalog";
import Layout from "../layouts/Layout.astro";

const searchItems = getSearchItems();
const guideBySlug = new Map(allRoundups.map((roundup) => [roundup.slug, roundup]));

const shoppingPaths = [
  {
    href: "/guides#travel-tech",
    eyebrow: "Travel tech",
    title: "Pack lighter and stay charged",
    description: "Power banks, trackers, headphones, and portable-work gear for trips and commutes.",
    count: allRoundups.filter((roundup) => roundup.cluster === "travel-tech").length
  },
  {
    href: "/guides#desk-home-office",
    eyebrow: "Desk setup",
    title: "Make a workday easier",
    description: "Keyboards, mice, stands, lighting, chargers, and small office fixes that earn desk space.",
    count: allRoundups.filter((roundup) => roundup.cluster === "home-office").length
  },
  {
    href: "/guides#coffee",
    eyebrow: "Coffee gear",
    title: "Improve the daily cup",
    description: "Brewers, grinders, kettles, frothers, and small-kitchen coffee choices.",
    count: allRoundups.filter((roundup) => roundup.cluster === "coffee-gear").length
  },
  {
    href: "/guides#home-upgrades",
    eyebrow: "Home upgrades",
    title: "Fix small home routines",
    description: "Storage, smart-home starters, air quality, cleaning, and practical apartment upgrades.",
    count: allRoundups.filter(
      (roundup) => roundup.cluster === "budget-finds" || roundup.category === "home"
    ).length
  }
];

const startingGuideSlugs = [
  "best-travel-tech-essentials",
  "best-desk-setup-products",
  "best-coffee-gear-for-beginners",
  "best-smart-home-starter-kit-under-100"
];

const startingGuides = startingGuideSlugs
  .map((slug) => guideBySlug.get(slug))
  .filter((roundup): roundup is (typeof allRoundups)[number] => Boolean(roundup));

const latestProducts = [...allProducts]
  .sort((a, b) => b.priceCheckedAt.localeCompare(a.priceCheckedAt) || a.title.localeCompare(b.title))
  .slice(0, 4);

const title = "Findsera | Find better products faster";
const description =
  "Start with clear shopping paths for travel tech, desk setups, coffee gear, and practical home upgrades on Findsera.";
---

<Layout title={title} description={description}>
  <section class="section-spacing">
    <div class="container-shell grid gap-10 xl:grid-cols-[minmax(0,0.9fr),minmax(0,1.1fr)] xl:items-center">
      <div class="space-y-6">
        <span class="eyebrow">Curated product discovery</span>
        <div class="max-w-3xl space-y-5">
          <h1 class="font-serif text-5xl font-semibold tracking-tight text-ink-900 sm:text-6xl">
            Start with the shopping path, not the product grid
          </h1>
          <p class="max-w-2xl text-lg leading-8 text-ink-700">
            Findsera keeps buying decisions smaller: choose a routine, compare a focused guide, then open the product
            details only when a pick fits.
          </p>
        </div>
        <HeaderSearch items={searchItems} />
        <div class="flex flex-wrap gap-3">
          <a
            href="/guides"
            class="inline-flex items-center rounded-full bg-ink-900 px-5 py-3 text-sm font-semibold text-white hover:bg-accent-600"
          >
            Browse guides
          </a>
          <a
            href="/products"
            class="inline-flex items-center rounded-full border border-black/10 bg-white px-5 py-3 text-sm font-semibold text-ink-900 hover:border-accent-500 hover:text-accent-600"
          >
            Search products
          </a>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {
          shoppingPaths.map((path) => (
            <a
              href={path.href}
              class="group rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card hover:border-accent-500/30"
            >
              <div class="flex items-start justify-between gap-4">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">{path.eyebrow}</p>
                <span class="rounded-full bg-sand-50 px-3 py-1 text-xs font-semibold text-ink-700">
                  {path.count} guides
                </span>
              </div>
              <h2 class="mt-4 font-serif text-3xl font-semibold tracking-tight text-ink-900 group-hover:text-accent-600">
                {path.title}
              </h2>
              <p class="mt-4 text-sm leading-7 text-ink-700">{path.description}</p>
              <span class="mt-6 inline-flex text-sm font-semibold text-ink-900 group-hover:text-accent-600">
                Open path
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="pb-16">
    <div class="container-shell">
      <SectionHeader
        title="Best Starting Points"
        description="Four useful guides for the most common Findsera shopping paths."
        href="/guides"
        linkLabel="See all guide groups"
      />
      <div class="grid gap-6 lg:grid-cols-4">
        {startingGuides.map((roundup) => <RoundupCard roundup={roundup} />)}
      </div>
    </div>
  </section>

  <section class="pb-16">
    <div class="container-shell grid gap-6 lg:grid-cols-[minmax(0,0.8fr),minmax(0,1.2fr)]">
      <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Catalog status</p>
        <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
          <a href="/products" class="rounded-[1.35rem] bg-sand-50 p-4 hover:bg-sand-100">
            <p class="text-sm font-semibold text-ink-700">Products with detail pages</p>
            <p class="mt-2 font-serif text-4xl font-semibold text-ink-900">{allProducts.length}</p>
          </a>
          <a href="/guides" class="rounded-[1.35rem] bg-sky-100/55 p-4 hover:bg-sky-100">
            <p class="text-sm font-semibold text-ink-700">Focused buying guides</p>
            <p class="mt-2 font-serif text-4xl font-semibold text-ink-900">{allRoundups.length}</p>
          </a>
        </div>
      </article>

      <article class="rounded-[1.75rem] border border-black/6 bg-white p-6 shadow-card">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Recently checked products</p>
            <h2 class="mt-3 font-serif text-3xl font-semibold tracking-tight text-ink-900">
              Price-check dates stay visible
            </h2>
          </div>
          <a href="/products" class="text-sm font-semibold text-accent-600 hover:text-accent-500">
            View catalog
          </a>
        </div>
        <div class="mt-6 grid gap-3 md:grid-cols-2">
          {
            latestProducts.map((product) => (
              <a
                href={`/products/${product.slug}`}
                class="rounded-[1.35rem] border border-black/6 bg-sand-50 p-4 hover:border-accent-500/30"
              >
                <p class="text-sm font-semibold text-ink-900">{product.title}</p>
                <p class="mt-2 text-xs font-semibold uppercase tracking-[0.14em] text-ink-700/70">
                  Checked {product.priceCheckedAt}
                </p>
              </a>
            ))
          }
        </div>
      </article>
    </div>
  </section>
</Layout>
