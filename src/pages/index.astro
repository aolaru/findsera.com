---
import ProductCard from "../components/ProductCard.astro";
import RoundupCard from "../components/RoundupCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import HeaderSearch from "../components/HeaderSearch.astro";
import {
  allProducts,
  allRoundups,
  getSearchItems,
  getProductsUnderPrice,
  getTrendingProducts,
  sortProductsByPrice
} from "../data/catalog";
import Layout from "../layouts/Layout.astro";

const trendingProducts = getTrendingProducts().slice(0, 6);
const underFifty = sortProductsByPrice(getProductsUnderPrice(50)).slice(0, 6);

const latestProducts = [...allProducts]
  .sort(
    (a, b) =>
      b.priceCheckedAt.localeCompare(a.priceCheckedAt) ||
      Number(b.isTrending) - Number(a.isTrending) ||
      a.title.localeCompare(b.title)
  )
  .slice(0, 3);

const latestGuides = [...allRoundups]
  .sort((a, b) => b.updatedAt.localeCompare(a.updatedAt) || a.title.localeCompare(b.title))
  .slice(0, 4);

const featuredGuide =
  allRoundups.find((roundup) => roundup.slug === "meater-plus-vs-thermapen-one") ?? latestGuides[0];

const newestProduct = latestProducts[0];
const featuredBudgetGuide =
  allRoundups.find((roundup) => roundup.slug === "best-products-under-50") ?? allRoundups[0];
const searchItems = getSearchItems();

const useCaseBlocks = [
  {
    href: "/best-travel-tech-under-100",
    eyebrow: "Travel setup",
    title: "Pack lighter, charge smarter, and work from anywhere",
    description:
      "Start with portable power, compact audio, and carry-on-friendly gear that earns space in a real travel bag."
  },
  {
    href: "/best-desk-setup-products",
    eyebrow: "Desk upgrades",
    title: "Build a better workday with compact desk improvements",
    description:
      "Browse the strongest keyboard, mouse, lamp, and organization upgrades for hybrid work and smaller desks."
  },
  {
    href: "/best-coffee-gear-for-beginners",
    eyebrow: "Coffee routine",
    title: "Upgrade your morning ritual without overbuilding the kitchen",
    description:
      "Find brewers, kettles, and coffee add-ons that improve daily drinks without turning the counter into a hobby project."
  }
];

const title = "Findsera | Find better products faster";
const description =
  "Discover curated products, simple buying guides, and practical picks across gadgets, home, and kitchen on Findsera.";
---

<Layout title={title} description={description}>
  <section class="section-spacing">
    <div class="container-shell hero-grid">
      <div class="space-y-6">
        <span class="eyebrow">Curated product discovery</span>
        <div class="max-w-3xl space-y-5">
          <h1 class="font-serif text-5xl font-semibold tracking-tight text-ink-900 sm:text-6xl">
            Find better products faster
          </h1>
          <p class="max-w-2xl text-lg leading-8 text-ink-700">
            Practical products and buying guides for travel, desk setups, coffee routines, and useful home upgrades.
            Start with search or browse the strongest picks below.
          </p>
        </div>
        <HeaderSearch items={searchItems} />
        <div class="flex flex-wrap gap-3">
          <a
            href={`/${featuredGuide.slug}`}
            class="inline-flex items-center rounded-full bg-ink-900 px-5 py-3 text-sm font-semibold text-white hover:bg-accent-600"
          >
            Read featured guide
          </a>
          <a
            href="/products"
            class="inline-flex items-center rounded-full border border-black/10 bg-white px-5 py-3 text-sm font-semibold text-ink-900 hover:border-accent-500 hover:text-accent-600"
          >
            Browse all products
          </a>
        </div>

        <div class="grid gap-4 pt-2 sm:grid-cols-3">
          <a href="/products" class="rounded-[1.4rem] border border-black/6 bg-white p-5 shadow-card hover:border-accent-500/30">
            <p class="text-sm font-semibold text-ink-700">Live catalog products</p>
            <p class="mt-2 font-serif text-4xl font-semibold text-ink-900">{allProducts.length}</p>
          </a>
          <a href="/guides" class="rounded-[1.4rem] border border-black/6 bg-white p-5 shadow-card hover:border-accent-500/30">
            <p class="text-sm font-semibold text-ink-700">Buying guides</p>
            <p class="mt-2 font-serif text-4xl font-semibold text-ink-900">{allRoundups.length}</p>
          </a>
          <a
            href={`/products/${newestProduct.slug}`}
            class="rounded-[1.4rem] border border-black/6 bg-white p-5 shadow-card hover:border-accent-500/30"
          >
            <p class="text-sm font-semibold text-ink-700">Newest live product</p>
            <p class="mt-2 font-serif text-xl font-semibold tracking-tight text-ink-900">{newestProduct.title}</p>
          </a>
        </div>
      </div>

      <aside class="rounded-[2rem] border border-black/6 bg-white p-6 shadow-card">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent-600">Featured guide</p>
        <div class="mt-5 rounded-[1.6rem] bg-[linear-gradient(180deg,#fff8f1,#fff)] p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-700/70">{featuredGuide.eyebrow}</p>
          <h2 class="mt-3 font-serif text-3xl font-semibold tracking-tight text-ink-900">
            <a href={`/${featuredGuide.slug}`} class="hover:text-accent-600">{featuredGuide.title}</a>
          </h2>
          <p class="mt-3 text-sm leading-7 text-ink-700">{featuredGuide.description}</p>
          <div class="mt-5 flex items-center justify-between gap-4 text-sm text-ink-700">
            <span>{featuredGuide.productCount} products</span>
            <span>Updated {featuredGuide.updatedAt}</span>
          </div>
          <a
            href={`/${featuredGuide.slug}`}
            class="mt-5 inline-flex items-center rounded-full bg-ink-900 px-4 py-3 text-sm font-semibold text-white hover:bg-accent-600"
          >
            Read the guide
          </a>
        </div>

        <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
          <a href={`/${featuredBudgetGuide.slug}`} class="rounded-[1.4rem] bg-sand-50 p-4 hover:bg-sand-100">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">Budget winner</p>
            <p class="mt-2 font-serif text-xl font-semibold tracking-tight text-ink-900">{featuredBudgetGuide.title}</p>
          </a>
          <a href="/guides" class="rounded-[1.4rem] bg-sky-100/55 p-4 hover:bg-sky-100">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">More picks</p>
            <p class="mt-2 font-serif text-xl font-semibold tracking-tight text-ink-900">Browse all buying guides</p>
          </a>
        </div>
      </aside>
    </div>
  </section>

  <section class="section-spacing">
    <div class="container-shell">
      <SectionHeader
        title="Shop by Use Case"
        description="Start with the clearest shopping paths instead of browsing the whole catalog at once."
      />
      <div class="grid gap-6 lg:grid-cols-3">
        {
          useCaseBlocks.map((block) => (
            <a
              href={block.href}
              class="group rounded-[1.8rem] border border-black/6 bg-white p-6 shadow-card hover:border-accent-500/30"
            >
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600">{block.eyebrow}</p>
              <h2 class="mt-3 font-serif text-3xl font-semibold tracking-tight text-ink-900 group-hover:text-accent-600">
                {block.title}
              </h2>
              <p class="mt-4 text-sm leading-7 text-ink-700">{block.description}</p>
              <span class="mt-6 inline-flex text-sm font-semibold text-ink-900 group-hover:text-accent-600">
                Explore picks
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section id="trending-now" class="section-spacing">
    <div class="container-shell">
      <SectionHeader
        title="Trending Now"
        description="Current product picks with practical use cases and quick paths to compare or buy."
        href="/products"
        linkLabel="See all products"
      />
      <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
        {trendingProducts.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>

  <section class="section-spacing">
    <div class="container-shell">
      <SectionHeader
        title="Under $50"
        description="Lower-risk picks that are easy to gift, test, or add to a routine."
        href="/best-products-under-50"
        linkLabel="See the full list"
      />
      <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
        {underFifty.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>

  <section class="section-spacing">
    <div class="container-shell">
      <SectionHeader
        title="Best Guides"
        description="Start with the most useful buying guides and comparisons."
        href="/guides"
        linkLabel="See every guide"
      />
      <div class="grid gap-6 lg:grid-cols-3">
        {allRoundups.slice(0, 6).map((roundup) => <RoundupCard roundup={roundup} />)}
      </div>
    </div>
  </section>
</Layout>
