---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  robots?: string;
  adsenseEnabled?: boolean;
  image?: string;
  structuredData?: Record<string, unknown>;
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  robots = "index, follow",
  adsenseEnabled = true,
  image = "/images/findsera-social-card.svg",
  structuredData
} = Astro.props;

const siteOrigin = Astro.site ?? new URL(Astro.url.origin);
const hasFileExtension = (pathname: string) => /\.[a-z0-9]+$/i.test(pathname);
const normalizeUrl = (value: string) => {
  const url = new URL(value, siteOrigin);

  if (url.origin === siteOrigin.toString().replace(/\/$/, "") && !hasFileExtension(url.pathname)) {
    url.pathname = url.pathname === "/" ? "/" : `${url.pathname.replace(/\/$/, "")}/`;
  }

  return url.toString();
};

const canonicalUrl = normalizeUrl(canonicalPath);
const socialImageUrl = new URL(image, siteOrigin).toString();
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const analyticsId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? "G-8T3PBQ9MMP";
const analyticsEnabled = import.meta.env.PUBLIC_ENABLE_ANALYTICS !== "false";
const adsenseApproved = import.meta.env.PUBLIC_ENABLE_ADSENSE === "true";
const shouldLoadAdSense = adsenseEnabled && adsenseApproved && !robots.toLowerCase().includes("noindex");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon-180.png" />
    <meta name="theme-color" content="#e97d2f" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={robots} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Findsera" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="google-adsense-account" content="ca-pub-4706844277814411" />
    {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
    {
      shouldLoadAdSense && (
        <script
          async
          src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4706844277814411"
          crossorigin="anonymous"
        ></script>
      )
    }
    <script is:inline define:vars={{ analyticsId, analyticsEnabled }}>
      window.dataLayer = window.dataLayer || [];
      window.gtag = window.gtag || function gtag() {
        window.dataLayer.push(arguments);
      };

      (() => {
        const storageKey = "findsera_cookie_choice";
        const banner = document.querySelector("[data-consent-banner]");
        const acceptButton = document.querySelector("[data-consent-accept]");
        const declineButton = document.querySelector("[data-consent-decline]");
        let loaded = false;

        const loadAnalytics = () => {
          if (!analyticsEnabled || loaded) return;
          loaded = true;
          const script = document.createElement("script");
          script.async = true;
          script.src = `https://www.googletagmanager.com/gtag/js?id=${analyticsId}`;
          document.head.appendChild(script);
          window.gtag("js", new Date());
          window.gtag("config", analyticsId, { anonymize_ip: true });
        };

        const setChoice = (choice) => {
          try {
            window.localStorage.setItem(storageKey, choice);
          } catch (error) {
            // Ignore blocked storage and keep the page usable.
          }
          banner?.classList.add("hidden");
          if (choice === "accepted") loadAnalytics();
        };

        const getChoice = () => {
          try {
            return window.localStorage.getItem(storageKey);
          } catch (error) {
            return null;
          }
        };

        const choice = getChoice();
        if (choice === "accepted") loadAnalytics();
        else if (!choice) banner?.classList.remove("hidden");

        acceptButton?.addEventListener("click", () => setChoice("accepted"));
        declineButton?.addEventListener("click", () => setChoice("declined"));

        document.addEventListener("click", (event) => {
          const link = event.target.closest("a[href*='amazon.com']");

          if (!link || typeof window.gtag !== "function") {
            return;
          }

          window.gtag("event", "affiliate_click", {
            event_category: "affiliate",
            event_label: link.dataset.productId || link.textContent.trim(),
            link_url: link.href,
            page_path: window.location.pathname
          });
        });
      })();
    </script>
    {
      structuredData && (
        <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
      )
    }
  </head>
  <body class="m-0">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <div
      data-consent-banner
      class="hidden fixed inset-x-4 bottom-4 z-50 mx-auto max-w-3xl rounded-[1.25rem] border border-black/10 bg-white p-4 text-sm leading-6 text-ink-700 shadow-card"
    >
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <p>
          Findsera uses optional analytics cookies to understand aggregate traffic. Affiliate links work without
          accepting analytics.
        </p>
        <div class="flex shrink-0 gap-2">
          <button
            type="button"
            data-consent-decline
            class="rounded-full border border-black/10 bg-white px-4 py-2 text-sm font-semibold text-ink-900 hover:border-accent-500"
          >
            Decline
          </button>
          <button
            type="button"
            data-consent-accept
            class="rounded-full bg-ink-900 px-4 py-2 text-sm font-semibold text-white hover:bg-accent-600"
          >
            Accept
          </button>
        </div>
      </div>
    </div>
  </body>
</html>
